{
  "dxt_version": "0.2",
  "name": "yolken-test6-mcp",
  "version": "0.0.1",
  "description": "The official MCP Server for the Yolken Test6 API",
  "author": {
    "name": "Yolken Test6",
    "email": "benjamin3@stainless.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yolken/yolken-test6-typescript.git"
  },
  "homepage": "https://github.com/yolken/yolken-test6-typescript/tree/main/packages/mcp-server#readme",
  "documentation": "http://example16.com",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/index.js"
      ],
      "env": {
        "PETSTORE_API_KEY": "${user_config.PETSTORE_API_KEY}"
      }
    }
  },
  "user_config": {
    "PETSTORE_API_KEY": {
      "title": "api_key",
      "description": "",
      "required": true,
      "type": "string"
    }
  },
  "tools": [],
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": [
    "api"
  ]
}
